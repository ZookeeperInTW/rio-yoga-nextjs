generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id           String    @id @default(cuid())
  name         String
  phone        String    @unique
  passwordHash String
  initial      String
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  packages     Package[]
  bookings     Booking[]
}

model Package {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  total     Int
  remaining Int
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Branch {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  address  String
  studios  Studio[]
  bookings Booking[]
}

model Studio {
  id         String    @id @default(cuid())
  branchId   String
  branch     Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name       String
  kind       String
  capacity   Int
  hoursStart String
  hoursEnd   String
  bookings   Booking[]
}

model Service {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  durationMin     Int
  description     String
  bookings        Booking[]
  teacherServices TeacherService[]
}

model Teacher {
  id              String           @id @default(cuid())
  name            String
  yearsExp        Int
  joinedAt        DateTime
  sessions        Int              @default(0)
  hoursScheduled  Float            @default(0)
  avgRating       Float            @default(0)
  teacherServices TeacherService[]
  availability    Availability[]
  bookings        Booking[]
}

model TeacherService {
  teacherId String
  serviceId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([teacherId, serviceId])
}

model Availability {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  startHour Int
  endHour   Int
}

model Booking {
  id         String   @id @default(cuid())
  bookingRef String   @unique
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id])
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id])
  teacherId  String?
  teacher    Teacher? @relation(fields: [teacherId], references: [id])
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  studioId   String?
  studio     Studio?  @relation(fields: [studioId], references: [id])
  startTime  DateTime
  endTime    DateTime
  status     String   @default("confirmed")
  kind       String
  isInHome   Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
}
